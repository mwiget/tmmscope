   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "tmm-telemetry"
     },
     "expr": "sum by (tenant) (label_replace(rate(f5tmm_virtual_server_clientside_tot_conns{cluster=\"$cluster\"}[$__rate_interval]), \"tenant\", \"$1\", \"name\", \"tenant-([^-]+)-.*\"))",
     "legendFormat": "{{tenant}}"
    }
   ],
   "description": "Virtual-server accepts/s summed per tenant (both DPUs). Tenant parsed from the VS name, which embeds it."
  },
