{
 "id": null,
 "uid": "tmm-realtime",
 "title": "TMM Real-Time",
 "tags": [
  "tmm",
  "telemetry"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 3,
 "refresh": "5s",
 "time": {
  "from": "now-15m",
  "to": "now"
 },
 "templating": {
  "list": [
   {
    "name": "cluster",
    "type": "query",
    "datasource": {
     "type": "prometheus",
     "uid": "tmm-telemetry"
    },
    "query": {
     "query": "label_values(f5tmm_up, cluster)",
     "refId": "var"
    },
    "refresh": 2,
    "sort": 1,
    "includeAll": false,
    "multi": false,
    "current": {}
   }
  ]
 },
 "panels": [
  {
   "id": 1,
   "type": "timeseries",
   "title": "TMM CPU utilisation % (cycles-based, stacked by node)",
   "datasource": {
    "type": "prometheus",
    "uid": "tmm-telemetry"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 40,
      "showPoints": "never",
      "stacking": {
       "mode": "normal",
       "group": "A"
      }
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "lastNotNull",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi"
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "tmm-telemetry"
     },
     "expr": "(1 - rate(f5tmm_tmm_tm_idle_cycles{cluster=\"$cluster\"}[$__rate_interval]) / rate(f5tmm_tmm_tm_total_cycles{cluster=\"$cluster\"}[$__rate_interval])) * 100",
     "legendFormat": "{{node}}"
    }
   ]
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "TMM client throughput (bit/s)",
   "datasource": {
    "type": "prometheus",
    "uid": "tmm-telemetry"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bps",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10,
      "showPoints": "never"
     }
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "bottom",
     "calcs": [
      "lastNotNull",
      "max"
     ]
    },
    "tooltip": {
     "mode": "multi"
    }
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "tmm-telemetry"
     },
     "expr": "rate(f5tmm_tmm_client_side_traffic_bytes_in{cluster=\"$cluster\"}[$__rate_interval])*8",
     "legendFormat": "{{pod}}"
    }
   ]
  },
  {
