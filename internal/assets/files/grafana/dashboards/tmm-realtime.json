  {
   "id": 20,
   "type": "timeseries",
   "title": "Per-tenant connection rate (\u2248 req/s)",
   "datasource": {
    "type": "prometheus",
    "uid": "tmm-telemetry"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 24
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10,
      "showPoints": "never"
